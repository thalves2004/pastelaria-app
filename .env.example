# Copie a URL "Session pooler" do botão Connect no Supabase.
DATABASE_URL=postgresql://postgres.PROJECT_REF:SUA_SENHA@HOST.pooler.supabase.com:5432/postgres

# Use uma sequência longa e aleatória no Render.
SECRET_KEY=troque-por-uma-chave-longa-e-segura

# O Supabase exige conexão criptografada.
DATABASE_SSLMODE=require
